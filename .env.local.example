# ==============================================
# SAGE TAX CONSULTANCY - Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your values
# These MUST also be set in Vercel Dashboard > Settings > Environment Variables

# --- Supabase (Required) ---
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Site Config ---
NEXT_PUBLIC_SITE_URL=https://sagetaxconsultancy.com

# --- Google Analytics (Optional) ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- News APIs (for live news section) ---
# GNews.io (primary) - Get key from: https://gnews.io/dashboard
GNEWS_API_KEY=your-gnews-api-key-here

# NewsAPI.org (fallback) - Get key from: https://newsapi.org/account
NEWSAPI_API_KEY=your-newsapi-api-key-here

# --- Revalidation Secret (for on-demand ISR) ---
REVALIDATION_SECRET=your-random-secret-string-here

# --- Admin Email (for CMS login) ---
ADMIN_EMAIL=admin@sagetaxconsultancy.com
